{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": { "@/*": ["./client/src/*"] },
    "outDir": "./dist"
  },
  "include": ["client/src", "server", "drizzle"],
  "exclude": ["node_modules", "dist"]
}
